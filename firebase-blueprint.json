{
  "entities": {
    "profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "linkedin": { "type": "string" },
        "instagram": { "type": "string" },
        "address": { "type": "string" },
        "profileImage": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "maintenanceGroups": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "content": { "type": "string" },
              "order": { "type": "number" }
            }
          }
        }
      },
      "required": ["name", "email"]
    },
    "experience": {
      "title": "Experience",
      "description": "Professional experience entry",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "company": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "impact": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      }
    },
    "education": {
      "title": "Education",
      "description": "Education entry",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "school": { "type": "string" },
        "period": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "product": {
      "title": "Product",
      "description": "Product case study",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "problem": { "type": "string" },
        "bet": { "type": "string" },
        "decisions": { "type": "string" },
        "impact": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "number" }
      }
    },
    "visitor": {
      "title": "Visitor",
      "description": "Daily visitor count",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "count": { "type": "number" }
      }
    },
    "download": {
      "title": "Download",
      "description": "Resume download record",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "visitor_detail": {
      "title": "Visitor Detail",
      "description": "Detailed info about each visitor",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "location": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "log": {
      "title": "Log",
      "description": "System error log",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "message": { "type": "string" },
        "stack": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/profile/main": { "schema": "profile", "description": "Main profile data" },
    "/experience/{id}": { "schema": "experience", "description": "Experience entries" },
    "/education/{id}": { "schema": "education", "description": "Education entries" },
    "/products/{id}": { "schema": "product", "description": "Product case studies" },
    "/analytics/visitors/daily/{date}": { "schema": "visitor", "description": "Daily visitor stats" },
    "/analytics/visitors/details/{id}": { "schema": "visitor_detail", "description": "Individual visitor records" },
    "/analytics/system/logs/{id}": { "schema": "log", "description": "Error logs" },
    "/analytics/downloads/logs/{id}": { "schema": "download", "description": "Resume download logs" }
  }
}
